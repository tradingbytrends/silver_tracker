# Angel One SmartAPI credentials
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_CODE=your_client_code_here
ANGEL_PASSWORD=your_mpin_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# Silver instrument token (MCX Silver)
SILVER_SYMBOL=SILVER
SILVER_TOKEN=234230
SILVER_EXCHANGE=MCX

# Twilio WhatsApp credentials
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# Notification interval (minutes)
NOTIFICATION_INTERVAL_MIN=15
NOTIFICATION_INTERVAL_MAX=20

# Data fetch interval (seconds)
PRICE_FETCH_INTERVAL=60

# Database path
DB_PATH=data/silver_prices.db

# Logging level
LOG_LEVEL=INFO
